@model SendSmsCallAlerts.Models.SmsTemplate

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Sms Template</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="name" class="control-label">Name</label>
                <input asp-for="name" class="form-control" required />
                <span asp-validation-for="name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="templateBody" class="control-label">Template Body</label>
                <input asp-for="templateBody" class="form-control" required />
                <span asp-validation-for="templateBody" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Image</label>
                <div class="col-md-10">
                    <input type="file" name="ImgFile" id="ImgFile" accept="image/jpeg, image/png,image/jpg" />
                </div>
            </div>


            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
