@model List<SendSmsCallAlerts.Models.OptInstVM>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1>Option's Instruction</h1>
    <a asp-action="IncomingLogs" asp-controller="Sms" class="btn btn-secondary btn-sm">
        <i class="fa fa-arrow-left me-1"></i> Back to SMS Logs
    </a>
</div>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayName("Option")
            </th>
            <th>
                @Html.DisplayName("Instruction Order")
            </th>
            <th>
                @Html.DisplayName("Instruction")
            </th>
            <th>
                @Html.DisplayName("Twilio#")
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.OptionNumber)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.InstructionOrder)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Instruction)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TwilioNumber)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
