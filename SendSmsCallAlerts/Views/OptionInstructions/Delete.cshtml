@model SendSmsCallAlerts.Models.OptionInstructions

@{
    ViewData["Title"] = "Delete";
}

<h1>Are you sure you want to delete this Option's Instruction?</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayName("Option")
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IvrId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayName("Instruction Order")
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.InstructionOrder)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Instruction)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Instruction)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
