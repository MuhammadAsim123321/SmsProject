@model SendSmsCallAlerts.Models.IvrOptions

@{
    ViewData["Title"] = "Create";
}

<h1>Add an Option</h1>

@if (ViewBag.ErMsg != null)
{
    <div class="alert alert-danger">
        <b>@ViewBag.ErMsg </b>
    </div>
}

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Num" class="control-label">Option Number</label>
                <input asp-for="Num" type="number" class="form-control" />
                <span asp-validation-for="Num" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="keyword" class="control-label"></label>
                <input asp-for="keyword" class="form-control" />
                <span asp-validation-for="keyword" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

