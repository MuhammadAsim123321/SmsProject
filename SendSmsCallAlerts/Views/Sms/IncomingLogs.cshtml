    function openImage(imgPath) {
        // Open the image in a new tab
        window.open(imgPath, '_blank');
    }

    function EditRecord(id) {
        var url = '@Url.Action("SMS", "Conversations")';
        url += '?num=' + id;
        window.location.href = url;
    }   
    
    function DeleteRecord(id) {
        $.ajax({
            url: '/Sms/DeleteMsg',
            type: 'POST',
            data: { id: id },
            success: function (response) {
                if (response == "success") {
                    // Perform any necessary actions like showing success message
                    // Delete the row from the DataTable
                    var rowToDelete = RpmDatatable.row(function (idx, data, node) {
                        return data.id === id;
                    }).index();

                    RpmDatatable.row(rowToDelete).remove().draw(false);
                } else {
                    // Handle errors if needed
                }
            },
            error: function (xhr, status, error) {
                // Handle errors if needed
            }
        });
    }


