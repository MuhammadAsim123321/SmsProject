                    public JsonResult GetData(StatisticsTbl para)
        {
            IEnumerable<StatisticsViewModel>
    stats = null;
    string usrRole = HttpContext.Session.GetString("UserRole");

    if (usrRole == "STU_ADMIN")
    {
    if(para.storeId == -1)
    {
    stats = (from store in _db.Storess
    join statis in _db.Statisticss
    on store.Id equals statis.Store_Id
    // orderby statis.Dt descending
    select new StatisticsViewModel
    {
    DtStr = statis.Dt.ToString("MM-dd-yy"),
    TotalNoOfOrders = statis.NoOfOrders,
    NoOfUnits = statis.NoOfUnits,
    GrossSales = statis.GrossSales,
    Discounts = statis.Discounts,
    Returns = statis.Returns,
    Shipping = statis.Shipping,
    Gross_COGSD = statis.Gross_COGSD,
    TikTokAdSpend = statis.TikTok_AD_Spend,
    MetaAdSpned = statis.Meta_AD_Spend,
