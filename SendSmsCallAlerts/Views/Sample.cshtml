    //});



    function EditRecord(id){
        var url = '@Url.Action("Edit", "Statistics")';
        url += '?id=' + id;
        window.location.href = url;
    }


    function DeleteRecord(id) {
        var url = '@Url.Action("Delete", "Statistics")';
        url += '?id=' + id;
        window.location.href = url;
    }

    function loadStores() {

        $.ajax({
            type: "GET",
            url: "/Stores/GetStores",
            datatype: "Json",
            success: function (data) {
                $('#StoreId').empty();

                $('#StoreId').append('<option value="" selected="true" disabled>Choose Store</option>');
                $('#StoreId').append('<option value="-1">All</option>');

                $.each(data, function (index, value) {
                    $('#StoreId').append('<option value="' + value.id + '">' + value.name + '</option>');

                });
            }
        });
    }

    loadStores();

    $('#StoreId').on('change', function () {
        RpmDatatable.ajax.reload();
    });


