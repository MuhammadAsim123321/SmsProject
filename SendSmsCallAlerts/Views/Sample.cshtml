    Accounting_Fee = statis.Accounting_Fee,
    OperatorExp = statis.Operator_Exp,
    ShopifyFee = statis.Shopify_Fee,
    Apps = statis.Apps,
    VariableExpenses = statis.Variable_Expense,
    Support_Doc = statis.Support_Doc,
    StoreName = store.Name,
    Dt = statis.Dt,
    Description = statis.Description,
    Id = statis.Id
    })
    .Distinct()
    .ToList();
    stats = stats.OrderByDescending(d => d.Dt);
